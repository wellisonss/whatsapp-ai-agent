# =========================================================================
# Configuração de exemplo. Copie para `.env` e ajuste os valores.
#   cp .env.example .env
# NUNCA comite o seu `.env` real (ele já está no .gitignore).
# =========================================================================

# ---------- App ----------
APP_ENV=local
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000

# ---------- Identidade do bot (personalize sem tocar em código) ----------
BOT_NAME=Assistente
BOT_COMPANY=Sua Empresa
BOT_DESCRIPTION=atendimento ao cliente e informações institucionais
BOT_LANGUAGE=PT-BR
# Opcional: caminho para um arquivo que substitui TODO o system prompt.
SYSTEM_PROMPT_FILE=
# Habilita a tool de exemplo de faturamento/ERP.
SALES_TOOL_ENABLED=true

# ---------- LLM (Google Gemini) ----------
# Gere sua chave em https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=gemini-embedding-001

# ---------- Postgres (sessões + memória + checkpoint LangGraph) ----------
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chatbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------- Redis (fila + dedup + debounce) ----------
REDIS_URL=redis://redis:6379/0
INBOX_STREAM=chatbot:inbox
INBOX_GROUP=chatbot-workers
INBOX_DEBOUNCE_SECONDS=2.0

# ---------- Qdrant (RAG) ----------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chatbot_kb

# ---------- Reranker ----------
# RERANKER pode ser "cohere" (precisa COHERE_API_KEY) ou "off"
RERANKER=off
COHERE_API_KEY=

# ---------- WAHA (gateway WhatsApp) ----------
WAHA_BASE_URL=http://waha:3000
WAHA_API_KEY=change-me-strong-secret
WAHA_SESSION=default
WEBHOOK_PUBLIC_URL=http://chatbot-api:8000/webhook/waha
# Senha do dashboard do WAHA (http://localhost:3002)
WAHA_DASHBOARD_PASSWORD=change-me
# Números permitidos (só o dígito, sem @c.us), separados por vírgula.
# Vazio = aceita todos. Ex.: 5511999999999,5511888888888
ALLOWED_CHAT_IDS=

# ---------- Sistema externo de exemplo (ERP / API de relatório) ----------
# Endpoint consumido pela tool de faturamento de exemplo. Troque pelo seu.
ERP_SALES_URL=https://api.exemplo.com/relatorio-de-vendas
ERP_SALES_MODE=vendas

# ---------- Observabilidade (Langfuse, opcional) ----------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
